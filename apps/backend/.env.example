# ── 데이터베이스 ──────────────────────────────────────────────
# Railway Variables 탭에서 자동 제공
DATABASE_URL=postgresql://user:password@host:5432/sisaewang

# ── Redis ─────────────────────────────────────────────────────
# Railway Redis 서비스 추가 시 자동 제공
REDIS_URL=redis://default:password@host:6379

# ── 서버 ──────────────────────────────────────────────────────
PORT=3000
API_VERSION=v1
NODE_ENV=production
ALLOWED_ORIGINS=*

# ── KAMIS API (농산물유통정보) ────────────────────────────────
# 신청: https://www.kamis.or.kr -> 고객지원 -> OpenAPI 신청
KAMIS_API_KEY=your_kamis_cert_key_here
KAMIS_CERT_ID=your_email@example.com

# ── 공공데이터포털 API (경락가격) ─────────────────────────────
# 신청: https://data.go.kr -> "농산물 도매시장 경락가격" 검색
DATA_GO_KR_API_KEY=your_data_go_kr_api_key_here

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=30d

# ── Firebase (푸시 알림) ──────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
