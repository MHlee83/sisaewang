# ============================================================
# 시세왕 백엔드 환경변수 템플릿
# 실제 값은 Railway 환경변수 또는 로컬 .env에 설정
# .env 파일은 절대 git에 커밋하지 마세요!
# ============================================================

# ── 서버
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ── 데이터베이스 (PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require

# ── Redis (선택 — 없으면 자동 비활성화)
REDIS_URL=redis://USER:PASSWORD@HOST:6379

# ── JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# ── Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# ── Firebase Admin SDK
FIREBASE_PROJECT_ID=sisaewang-xxxxx
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@sisaewang-xxxxx.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── 데이터 수집 API
KAMIS_API_KEY=your_kamis_api_key
KAMIS_CERT_ID=your_kamis_cert_id
AUCTION_API_KEY=your_auction_api_key

# ── 보안
ADMIN_SECRET=your-admin-secret-for-internal-apis
ALLOWED_ORIGINS=https://sisaewang.kr,https://www.sisaewang.kr

# ── 모니터링
SENTRY_DSN=https://xxx@o0.ingest.sentry.io/000
